# ============================================================
# Meddash Environment Variables Template
# Copy this file to Meddash_organized_backend/.env and fill in real values
# NEVER commit real secrets to git
# ============================================================

# Supabase / PostgreSQL
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_KEY="sb_publishable_YOUR_KEY_HERE"

DB_USERNAME="postgres.YOUR_PROJECT"
DB_PASSWORD="YOUR_PASSWORD_HERE"
DB_HOST="aws-1-us-east-1.pooler.supabase.com"
DB_PORT="5432"
DB_NAME="postgres"

# URL-encoded connection string
SUPABASE_URI="postgresql://postgres.YOUR_PROJECT:YOUR_ENCODED_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# SerpAPI (for Google Scholar)
SERPAPI_KEY=YOUR_SERPAPI_KEY_HERE

# Google Gemini (for HITL disambiguation)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
