# ============================================================
# MEDDASH MONOREPO — ROOT .gitignore
# Protects secrets, build artifacts, and OS junk from commits.
# ============================================================

# ─── Secrets & Environment ──────────────────────────────────
*.env
*.env.*
!.env.example
*.pem
*.key

# ─── Python / Backend ───────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.dist-info/
env/
venv/
.venv/
*.sqlite3
*.db

# ─── Node / Frontend ────────────────────────────────────────
node_modules/
.next/
out/
dist/
.build/
*.tsbuildinfo

# ─── Logs (tracked selectively, bulk ignored) ───────────────
*.log

# ─── OS & Editor Artifacts ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Antigravity System Dirs (agent-managed, not source) ────
brain/
conversations/
knowledge/
annotations/
context_state/
implicit/
browser_recordings/
html_artifacts/
playground/
prompting/
autogen_env/
scratch/

# ─── Misc ───────────────────────────────────────────────────
installation_id
mcp_config.json
test_deepseek.py
/tmp/
